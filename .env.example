# Green Button Connect — Environment Variables
# Copy to .env.local for local development. NEVER commit .env.local.

# SilverBlaze / Ameren OAuth Credentials
SILVERBLAZE_CLIENT_ID=your-client-id
SILVERBLAZE_CLIENT_SECRET=your-client-secret
SILVERBLAZE_TOKEN_URL=https://aceapiuat.silverblazext.com/api/v1/oauth/token
SILVERBLAZE_AUTH_URL=https://acewebsiteuat.silverblazext.com/oauth/authorize
SILVERBLAZE_SCOPE=FB=1_3_4_5_13_14_18_37;IntervalDuration=900_3600_86400;BlockDuration=Daily;HistoryLength=63115200;SubscriptionFrequency=Daily;
SILVERBLAZE_API_BASE=https://aceapiuat.silverblazext.com/api/v1/Datacustodian/espi/1_1/resource
SILVERBLAZE_APP_INFO_ID=127
SILVERBLAZE_REGISTRATION_TOKEN=your-registration-token

# OAuth Callback URL (must match what is registered with SilverBlaze)
CALLBACK_URL=https://your-domain.com/greenbutton/oauth/callback
